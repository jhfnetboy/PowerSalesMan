# PowerSalesMan 配置。复制为 .env 并填写。

# ---- AI 打分 / 富集用的大模型 ----
# 支持两类:anthropic(Claude)或 openai(OpenAI 兼容,含 DeepSeek/GLM 等)
AI_PROVIDER=openai

# openai 兼容示例(DeepSeek):
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_API_KEY=

# anthropic 示例:
# AI_PROVIDER=anthropic
# AI_BASE_URL=https://api.anthropic.com
# AI_MODEL=claude-sonnet-5
# AI_API_KEY=

# 没有 key 也能跑:score 会退化成内置启发式打分(heuristic)。
